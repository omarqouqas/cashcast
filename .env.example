# Cashcast - Environment Configuration
# Domain: cashcast.money (primary)
# Legacy: cashflowforecaster.io (redirects to cashcast.money)

# App URL (used for Stripe redirect URLs)
# Development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_APP_URL=https://cashcast.money

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs (from your Stripe Dashboard)
# Pro tier
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=price_xxx
# Premium tier (legacy, optional)
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_PREMIUM_YEARLY=price_xxx

# Resend Configuration (Email)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx
# From email - must use a verified domain in Resend (https://resend.com/domains)
# Using onboarding@resend.dev only sends to the account owner's email (for testing)
RESEND_FROM_EMAIL=Cashcast <noreply@cashcast.money>
